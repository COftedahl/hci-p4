{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**.ts", "src/**/**.ts", "index.ts"],
  "exclude": ["node_modules"],
  "lib": ["es2015"],
  "types": ["node", "express"]
}